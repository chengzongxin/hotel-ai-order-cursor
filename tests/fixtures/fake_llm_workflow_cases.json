{
  "version": "0.1.0",
  "domain": "hotel_order_fake_llm_workflow",
  "description": "End-to-end LangGraph workflow evals with fake structured LLM and fake tools.",
  "cases": [
    {
      "id": "single_repair_select_then_missing_time",
      "title": "单次维修首轮商品选择，选中后追问期望时间",
      "turns": [
        "1208房间空调不制冷",
        "第一个"
      ],
      "expected": {
        "phase": "pre_order",
        "service_type": "单次维修服务",
        "selected_code": "AC_REPAIR",
        "order_info": {
          "room_number": "1208",
          "product": "空调",
          "fault": "不制冷"
        },
        "missing_info": ["expected_start_time"]
      }
    },
    {
      "id": "single_repair_time_followup_reaches_confirm",
      "title": "多轮补充期望时间后进入预下单确认",
      "turns": [
        "1208房间空调不制冷",
        "第一个",
        "明天上午"
      ],
      "expected": {
        "phase": "pre_order",
        "service_type": "单次维修服务",
        "selected_code": "AC_REPAIR",
        "order_info": {
          "room_number": "1208",
          "product": "空调",
          "fault": "不制冷",
          "expected_start_time": "明天上午"
        },
        "missing_info": []
      }
    },
    {
      "id": "install_missing_goods_arrival",
      "title": "安装单选中商品后缺货物到场状态",
      "turns": [
        "1208房间洗衣机需要安装，明天上午",
        "第一个"
      ],
      "expected": {
        "phase": "pre_order",
        "service_type": "单次安装",
        "selected_code": "WASHER_INSTALL",
        "order_info": {
          "room_number": "1208",
          "product": "洗衣机",
          "expected_start_time": "明天上午"
        },
        "missing_info": ["goods_arrival_status"]
      }
    },
    {
      "id": "reject_products_returns_collecting",
      "title": "用户拒绝候选商品后返回收集中",
      "turns": [
        "1208房间空调不制冷",
        "以上都不符合"
      ],
      "expected": {
        "phase": "collecting",
        "service_type": null,
        "selected_code": null,
        "products_count": 0,
        "selection_rejected": true
      }
    },
    {
      "id": "cancel_active_order",
      "title": "活跃订单取消后清空商品和订单信息",
      "turns": [
        "1208房间空调不制冷",
        "取消，不用了"
      ],
      "expected": {
        "phase": "cancelled",
        "products_count": 0,
        "order_info": {}
      }
    }
  ]
}
